{
  "manifest_version": 3,
  "name": "Test Memory Aquarium",
  "version": "1.0.0",

  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_trans.png",
      "48": "icons/icon48_trans.png",
      "128": "icons/icon128_trans.png"
    }
  },


  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["src/fonts/*.woff2","BGImg.png", "icons/*"]
    }
  ]
}