{
  "manifest_version": 3,
  "name": "My Widget",
  "version": "1.0.0",

  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html"
  },


  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["src/fonts/*.woff2","BGImg.png", "icons/*"]
    }
  ]
}